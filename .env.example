# Copy this file to .env and fill in the value after deploying the SAM backend.
# The API URL is printed at the end of a successful sam deploy, or run:
#   aws cloudformation describe-stacks --stack-name dnd-character-builder \
#     --region us-west-1 \
#     --query "Stacks[0].Outputs[?OutputKey=='ApiUrl'].OutputValue" --output text

VITE_API_URL=https://xxxxxxxxxx.execute-api.us-west-1.amazonaws.com
